      "status": "todo",
      "title": "Warn early when recording workflows need ffmpeg before record stop",
      "priority": "medium",
      "tags": [
        "agent-browser",
        "recording",
        "ffmpeg",
        "artifacts",
        "diagnostics"
      ],
      "scope": [
