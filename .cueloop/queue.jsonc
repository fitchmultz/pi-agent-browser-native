        "test/agent-browser.presentation.test.ts",
        "test/agent-browser.extension-validation.test.ts"
      ],
      "evidence": [
        "dogfood 2026-05-14 static/docs pass :: command `title` returned unknown command; `get title` and `get url` worked.",
        "dogfood 2026-05-14 static/docs pass :: `eval --stdin` with `() => ({ title: document.title })` returned `{ result: {} }`, while a bare object expression returned expected values."
      ],
      "plan": [
        "Add unknown-command suggestions for common getter guesses such as `title`, `url`, and text extraction where presentation has enough context.",
        "Clarify `eval --stdin` expected expression/function semantics in command reference and prompt guidance.",
