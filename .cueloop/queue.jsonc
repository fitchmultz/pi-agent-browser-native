        "extensions/agent-browser/index.ts",
        "docs/TOOL_CONTRACT.md",
        "test"
      ],
      "evidence": [
        "The goal is to help agents tell whether a click navigated, opened a modal, created an artifact, caused console/page errors, or failed silently without needing another full dump.",
        "Page-change summaries are a direct way to reduce model-visible output and redundant follow-up calls."
      ],
      "plan": [
        "Identify the reliable before/after signals available around mutating commands: URL, title, tab identity, visible useful controls when available, artifacts, console/page errors, and failed network requests.",
        "Return a compact change summary after click, fill/submit, navigation, batch, download, and other mutation-prone commands without bloating read-only commands.",
        "Integrate summaries with categories and nextActions so changes and recommended follow-up are consistent.",
        "Add benchmark assertions for output-size and call-count effects."
      ],
      "notes": [],
      "request": "Infer and queue compact page-change summary work from the user's ABN task list.",
