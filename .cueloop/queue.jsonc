        "extensions/agent-browser/lib/results/shared.ts",
        "docs/TOOL_CONTRACT.md",
        "docs/COMMAND_REFERENCE.md",
        "README.md",
        "test/agent-browser.extension-validation.test.ts",
        "test/agent-browser.presentation.test.ts"
      ],
      "evidence": [
        "First Grafana VFR-style stress test failed at `record stop` with `ffmpeg not found or failed to execute`, after `record start` had appeared to begin successfully.",
        "README and docs now list ffmpeg as required for recordings, but the native tool can still provide earlier situational warning for recording workflows."
      ],
      "plan": [
        "Decide the least invasive preflight point: wrapper-side PATH check for `record start`, a warning after `record start`, or a pre-stop diagnostic before invoking upstream.",
        "Surface a concise warning/details field without blocking users when upstream behavior may support non-ffmpeg paths in the future.",
        "Keep docs aligned: record start may not create a file yet; record stop needs ffmpeg to encode WebM.",
        "Add tests for missing and present ffmpeg paths using dependency injection/fake process behavior."
      ],
      "notes": [],
