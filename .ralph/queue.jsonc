        "extensions/agent-browser/index.ts",
        "npm run verify"
      ],
      "evidence": [
        "path: README.md:213-228 :: README uses shell-like inspection wording and documents post-command tab restoration",
        "path: docs/COMMAND_REFERENCE.md:226-256 :: command reference documents stateless inspection but omits the implemented post-command tab-restoration behavior",
        "path: docs/REQUIREMENTS.md:99-104 :: requirements say the command reference and prompt guidance must stay in sync with wrapper behavior",
        "path: extensions/agent-browser/index.ts:70-99 :: another hand-maintained copy of the same browser workflow lives in prompt-guidance arrays"
